{
  "name": "Appraise",
  "secrets": [
    {
      "key": "ADMIN_USERNAMES",
      "description": "Comma/space-separated list of Usernode usernames who can delete voting rounds. Leave unset for no admins in production.",
      "required": false,
      "private": true
    }
  ],
  "tests": [
    {
      "name": "Round list renders",
      "path": "/",
      "expectText": "Voting Rounds"
    },
    {
      "name": "Create form opens",
      "path": "/create",
      "expectText": "Build a Voting Round"
    },
    {
      "name": "Self-vote toggle present",
      "path": "/create",
      "expectText": "Allow people to vote on their own app"
    },
    {
      "name": "Self-vote round shows note",
      "path": "/round/staging-selfvote-off",
      "expectText": "no self-voting"
    },
    {
      "name": "Open round detail",
      "path": "/round/staging-fav-dev-tools",
      "expectText": "Favorite Dev Tools"
    },
    {
      "name": "Closed round shows results",
      "path": "/round/staging-best-game",
      "expectText": "RESULTS"
    },
    {
      "name": "Admin delete affordance",
      "path": "/round/staging-deletable-demo",
      "expectText": "Delete round"
    },
    {
      "name": "Admin edit affordance",
      "path": "/round/staging-fav-dev-tools",
      "expectText": "Edit round details"
    },
    {
      "name": "List shows admin delete buttons",
      "path": "/",
      "expectSelector": ".del-row"
    },
    {
      "name": "Testers-only toggle present",
      "path": "/create",
      "expectText": "tested all the apps"
    },
    {
      "name": "Restricted round shows disclaimer",
      "path": "/round/staging-tested-gate",
      "expectText": "you have to test all the apps part of the voting round"
    },
    {
      "name": "Restricted round shows per-app untested notice",
      "path": "/round/staging-tested-gate",
      "expectText": "You haven't tested this app yet"
    },
    {
      "name": "Name-fallback round renders eligible ballot with demo pass",
      "path": "/round/staging-name-fallback?demo=1",
      "expectSelector": ".inc"
    },
    {
      "name": "Unenforceable round surfaces can't-enforce note",
      "path": "/round/staging-unenforceable-gate",
      "expectText": "can't be enforced for"
    },
    {
      "name": "Public voter leaderboard API",
      "path": "/api/leaderboard?round=staging-voting-progress",
      "expectText": "votes_remaining"
    },
    {
      "name": "Vote distribution control present",
      "path": "/create",
      "expectText": "Vote distribution"
    },
    {
      "name": "Concentrate round shows rule badge",
      "path": "/round/staging-fav-dev-tools",
      "expectText": "concentrate allowed"
    },
    {
      "name": "One-per-app round shows rule badge",
      "path": "/round/staging-one-per-app",
      "expectText": "one vote per app"
    },
    {
      "name": "Favicon resolves without auth",
      "path": "/favicon.ico"
    }
  ],
  "visibility": {
    "build": "private",
    "view": "public"
  }
}
